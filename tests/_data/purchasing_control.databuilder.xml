<?xml version="1.0"?>
<transfers
    xmlns="spryker:databuilder-01"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="spryker:databuilder-01 http://static.spryker.com/databuilder-01.xsd"
>

    <transfer name="CostCenter" strict="true">
        <property name="name" dataBuilderRule="unique()->words(3, true)"/>
        <property name="description" dataBuilderRule="sentence()"/>
        <property name="isActive" dataBuilderRule="boolean()"/>
    </transfer>

    <transfer name="Budget" strict="true">
        <property name="name" dataBuilderRule="unique()->words(3, true)"/>
        <property name="amount" dataBuilderRule="numberBetween(100, 1000000)"/>
        <property name="currencyIsoCode" dataBuilderRule="randomElement(['EUR', 'USD', 'GBP'])"/>
        <property name="startsAt" dataBuilderRule="date('Y-m-d', strtotime('-30 days'))"/>
        <property name="endsAt" dataBuilderRule="date('Y-m-d', strtotime('+30 days'))"/>
        <property name="enforcementRule" dataBuilderRule="randomElement(['block','warn','require_approval'])"/>
        <property name="isActive" dataBuilderRule="boolean()"/>
    </transfer>

</transfers>
