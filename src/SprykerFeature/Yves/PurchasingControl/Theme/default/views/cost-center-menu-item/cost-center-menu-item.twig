{% extends template('widget') %}

{% define data = {
    isActivePage: _widget.isActivePage,
    canManage: can('ManageCostCentersPermissionPlugin'),
} %}

{% set itemClass = data.isActivePage ? ' menu__item--active' : '' %}

{% block body %}
    {% if data.canManage %}
        <li class="menu__item {{ itemClass }}">
            <a href="{{ url('company/cost-center') }}">{{ 'purchasing_control.cost_center.menu_item' | trans }}</a>
        </li>
    {% endif %}
{% endblock %}
