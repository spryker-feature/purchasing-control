<?xml version="1.0"?>
<transfers xmlns="spryker:transfer-01"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="spryker:transfer-01 http://static.spryker.com/transfer-01.xsd">

    <transfer name="CostCenter" strict="true">
        <property name="idCostCenter" type="int"/>
        <property name="companyBusinessUnitIds" type="int[]" singular="idCompanyBusinessUnit"/>
        <property name="companyBusinessUnits" type="CompanyBusinessUnit[]" singular="companyBusinessUnit"/>
        <property name="name" type="string"/>
        <property name="company" type="string"/>
        <property name="description" type="string"/>
        <property name="isActive" type="bool"/>
        <property name="uuid" type="string"/>
        <property name="budgets" type="Budget[]" singular="budget"/>
        <property name="createdAt" type="string"/>
        <property name="updatedAt" type="string"/>
    </transfer>

    <transfer name="CostCenterCollection" strict="true">
        <property name="costCenters" type="CostCenter[]" singular="costCenter"/>
        <property name="pagination" type="Pagination"/>
    </transfer>

    <transfer name="CostCenterCriteria" strict="true">
        <property name="costCenterConditions" type="CostCenterConditions"/>
        <property name="sortCollection" type="Sort[]" singular="sort"/>
        <property name="pagination" type="Pagination"/>
    </transfer>

    <transfer name="CostCenterConditions" strict="true">
        <property name="costCenterIds" type="int[]" singular="idCostCenter"/>
        <property name="uuids" type="string[]" singular="uuid"/>
        <property name="companyBusinessUnitIds" type="int[]" singular="idCompanyBusinessUnit"/>
        <property name="companyIds" type="int[]" singular="idCompany"/>
        <property name="name" type="string"/>
        <property name="isActive" type="bool"/>
        <property name="currencyIsoCodes" type="string[]" singular="currencyIsoCode"/>
        <property name="withBudgets" type="bool"/>
        <property name="withInactiveBudgets" type="bool"/>
        <property name="budgetActiveOnDate" type="string"/>
        <property name="salesOrderIds" type="int[]" singular="idSalesOrder"/>
    </transfer>

    <transfer name="CostCenterResponse" strict="true">
        <property name="costCenter" type="CostCenter"/>
        <property name="isSuccessful" type="bool"/>
        <property name="errors" type="Message[]" singular="error"/>
    </transfer>

    <transfer name="CostCenterCollectionRequest" strict="true">
        <property name="costCenters" type="CostCenter[]" singular="costCenter"/>
        <property name="isTransactional" type="bool"/>
        <property name="customer" type="Customer"/>
    </transfer>

    <transfer name="CostCenterCollectionResponse" strict="true">
        <property name="costCenters" type="CostCenter[]" singular="costCenter"/>
        <property name="errors" type="Error[]" singular="error"/>
    </transfer>

    <transfer name="Error">
        <property name="message" type="string"/>
        <property name="entityIdentifier" type="string"/>
    </transfer>

    <transfer name="Budget" strict="true">
        <property name="idBudget" type="int"/>
        <property name="idCostCenter" type="int"/>
        <property name="name" type="string"/>
        <property name="amount" type="int"/>
        <property name="consumedAmount" type="int"/>
        <property name="remainingAmount" type="int"/>
        <property name="currencyIsoCode" type="string"/>
        <property name="startsAt" type="string"/>
        <property name="endsAt" type="string"/>
        <property name="enforcementRule" type="string"/>
        <property name="isActive" type="bool"/>
        <property name="uuid" type="string"/>
        <property name="createdAt" type="string"/>
        <property name="updatedAt" type="string"/>
    </transfer>

    <transfer name="BudgetCollection" strict="true">
        <property name="budgets" type="Budget[]" singular="budget"/>
        <property name="pagination" type="Pagination"/>
    </transfer>

    <transfer name="BudgetCriteria" strict="true">
        <property name="budgetConditions" type="BudgetConditions"/>
        <property name="sortCollection" type="Sort[]" singular="sort"/>
        <property name="pagination" type="Pagination"/>
    </transfer>

    <transfer name="BudgetConditions" strict="true">
        <property name="budgetIds" type="int[]" singular="idBudget"/>
        <property name="uuids" type="string[]" singular="uuid"/>
        <property name="costCenterIds" type="int[]" singular="idCostCenter"/>
        <property name="currencyIsoCodes" type="string[]" singular="currencyIsoCode"/>
        <property name="activeOnDate" type="string"/>
        <property name="isActive" type="bool"/>
        <property name="withBudgetConsumption" type="bool"/>
        <property name="startsAtFrom" type="string"/>
        <property name="endsAtTo" type="string"/>
        <property name="names" type="string[]" singular="name"/>
        <property name="enforcementRules" type="string[]" singular="enforcementRule"/>
    </transfer>

    <transfer name="BudgetResponse" strict="true">
        <property name="budget" type="Budget"/>
        <property name="isSuccessful" type="bool"/>
        <property name="errors" type="Message[]" singular="error"/>
    </transfer>

    <transfer name="BudgetCollectionRequest" strict="true">
        <property name="budgets" type="Budget[]" singular="budget"/>
        <property name="isTransactional" type="bool"/>
        <property name="customer" type="Customer"/>
    </transfer>

    <transfer name="BudgetCollectionResponse" strict="true">
        <property name="budgets" type="Budget[]" singular="budget"/>
        <property name="errors" type="Error[]" singular="error"/>
    </transfer>

    <transfer name="BudgetConsumption" strict="true">
        <property name="idBudgetConsumption" type="int"/>
        <property name="idBudget" type="int"/>
        <property name="idSalesOrder" type="int"/>
        <property name="amount" type="int"/>
    </transfer>

    <transfer name="BudgetConsumptionCollection" strict="true">
        <property name="budgetConsumptions" type="BudgetConsumption[]" singular="budgetConsumption"/>
    </transfer>

    <transfer name="BudgetConsumptionCriteria" strict="true">
        <property name="budgetConsumptionConditions" type="BudgetConsumptionConditions"/>
    </transfer>

    <transfer name="BudgetConsumptionConditions" strict="true">
        <property name="salesOrderIds" type="int[]" singular="idSalesOrder"/>
    </transfer>

    <transfer name="CostCenterQuoteUpdateRequest" strict="true">
        <property name="idQuote" type="int"/>
        <property name="idCostCenter" type="int"/>
        <property name="idBudget" type="int"/>
        <property name="customer" type="Customer"/>
    </transfer>

    <transfer name="CostCenterQuoteUpdateResponse" strict="true">
        <property name="isSuccessful" type="bool"/>
        <property name="quote" type="Quote"/>
        <property name="errors" type="Error[]" singular="error"/>
    </transfer>

    <transfer name="Quote">
        <property name="idCostCenter" type="int"/>
        <property name="idBudget" type="int"/>
        <property name="costCenter" type="CostCenter"/>
        <property name="budget" type="Budget"/>
        <property name="currency" type="Currency"/>
        <property name="totals" type="Totals"/>
        <property name="customer" type="Customer"/>
        <property name="customerReference" type="string"/>
        <property name="idQuote" type="int"/>
        <property name="isLocked" type="bool"/>
        <property name="expenses" type="Expense[]" singular="expense"/>
        <property name="quoteApprovals" type="QuoteApproval[]" singular="quoteApproval"/>
    </transfer>

    <transfer name="QuoteApproval">
        <property name="status" type="string"/>
    </transfer>

    <transfer name="Customer">
        <property name="customerReference" type="string"/>
        <property name="companyUserTransfer" type="CompanyUser"/>
    </transfer>

    <transfer name="CheckoutResponse">
        <property name="errors" type="CheckoutError[]" singular="error"/>
        <property name="saveOrder" type="SaveOrder"/>
        <property name="isSuccess" type="bool"/>
    </transfer>

    <transfer name="CheckoutError">
        <property name="message" type="string"/>
    </transfer>

    <transfer name="Message">
        <property name="value" type="string"/>
    </transfer>

    <transfer name="SaveOrder">
        <property name="idSalesOrder" type="int"/>
        <property name="orderItems" type="Item[]" singular="orderItem"/>
    </transfer>

    <transfer name="Item">
        <property name="idSalesOrderItem" type="int"/>
        <property name="sumPriceToPayAggregation" type="int"/>
        <property name="shipment" type="Shipment"/>
        <property name="refundableAmount" type="int"/>
        <property name="state" type="ItemState"/>
    </transfer>

    <transfer name="Shipment">
        <property name="idSalesShipment" type="int"/>
        <property name="price" type="int"/>
    </transfer>

    <transfer name="Expense">
        <property name="type" type="string"/>
        <property name="sumPrice" type="int"/>
        <property name="shipment" type="Shipment"/>
        <property name="refundableAmount" type="int"/>
        <property name="sumPriceToPayAggregation" type="int"/>
    </transfer>

    <transfer name="Order">
        <property name="idSalesOrder" type="int"/>
        <property name="fkBudget" type="int"/>
        <property name="fkCostCenter" type="int"/>
        <property name="costCenter" type="CostCenter"/>
        <property name="budget" type="Budget"/>
        <property name="items" type="Item[]" singular="item"/>
        <property name="expenses" type="Expense[]" singular="expense"/>
        <property name="companyUuid" type="string"/>
        <property name="companyName" type="string"/>
    </transfer>

    <transfer name="StoreWithCurrency">
        <property name="currencies" type="Currency[]" singular="currency"/>
    </transfer>

    <transfer name="Pagination">
        <property name="page" type="int"/>
        <property name="limit" type="int"/>
        <property name="offset" type="int"/>
        <property name="maxPerPage" type="int"/>
        <property name="nbResults" type="int"/>
        <property name="firstIndex" type="int"/>
        <property name="lastIndex" type="int"/>
        <property name="firstPage" type="int"/>
        <property name="lastPage" type="int"/>
        <property name="nextPage" type="int"/>
        <property name="previousPage" type="int"/>
    </transfer>

    <transfer name="CompanyBusinessUnitCriteriaFilter">
        <property name="pagination" type="Pagination"/>
        <property name="companyBusinessUnitIds" type="array" singular="companyBusinessUnitIds"/>
        <property name="idCompany" type="int"/>
        <property name="filter" type="Filter"/>
    </transfer>

    <transfer name="CompanyBusinessUnitCollection">
        <property name="companyBusinessUnits" type="CompanyBusinessUnit[]" singular="companyBusinessUnit"/>
    </transfer>

    <transfer name="CompanyBusinessUnit">
        <property name="idCompanyBusinessUnit" type="int"/>
        <property name="name" type="string"/>
        <property name="fkCompany" type="int"/>
        <property name="company" type="Company"/>
    </transfer>

    <transfer name="Currency">
        <property name="code" type="string"/>
    </transfer>

    <transfer name="Totals">
        <property name="grandTotal" type="int"/>
    </transfer>

    <transfer name="CompanyUser">
        <property name="idCompanyUser" type="int"/>
        <property name="fkCompany" type="int"/>
        <property name="fkCompanyBusinessUnit" type="int"/>
    </transfer>

    <transfer name="Sort">
        <property name="field" type="string"/>
        <property name="isAscending" type="bool"/>
    </transfer>

    <transfer name="QuoteResponse">
        <property name="isSuccessful" type="bool"/>
        <property name="quoteTransfer" type="Quote"/>
        <property name="errors" type="QuoteError[]" singular="error"/>
    </transfer>

    <transfer name="CompanyUserCollection">
        <property name="companyUsers" type="CompanyUser[]" singular="companyUser"/>
    </transfer>

    <transfer name="Company">
        <property name="name" type="string"/>
        <property name="uuid" type="string"/>
    </transfer>

    <transfer name="CompanyResponse">
        <property name="companyTransfer" type="Company"/>
        <property name="isSuccessful" type="bool"/>
    </transfer>

    <transfer name="QuoteError">
        <property name="message" type="string"/>
    </transfer>

    <transfer name="Money">
        <property name="amount" type="string"/>
        <property name="currency" type="Currency"/>
    </transfer>

    <transfer name="DataImporterConfiguration">
    </transfer>

    <transfer name="DataImporterDataSourceConfiguration">
        <property name="importType" type="string"/>
        <property name="fileName" type="string"/>
        <property name="moduleName" type="string"/>
        <property name="directory" type="string"/>
    </transfer>

    <transfer name="DataImporterReport">
    </transfer>

    <transfer name="ItemState">
        <property name="name" type="string"/>
    </transfer>

    <transfer name="Translation">
        <property name="glossaryKey" type="GlossaryKey" strict="true"/>
        <property name="value" type="string"/>
    </transfer>

    <transfer name="GlossaryKey">
        <property name="key" type="string"/>
    </transfer>

    <transfer name="Filter">
        <property name="limit" type="int"/>
    </transfer>

    <transfer name="OrderTableCriteria" strict="true">
        <property name="costCenterIds" type="int[]" singular="idCostCenter"/>
        <property name="budgetIds" type="int[]" singular="idBudget"/>
    </transfer>

    <transfer name="Store">
        <property name="availableCurrencyIsoCodes" type="array" singular="availableCurrencyIsoCode"/>
    </transfer>

    <transfer name="OrderList">
        <property name="filterFields" type="FilterField[]" singular="filterField"/>
    </transfer>

    <transfer name="FilterField">
        <property name="type" type="string"/>
        <property name="value" type="string"/>
    </transfer>

    <transfer name="QueryJoinCollection">
        <property name="queryJoins" type="QueryJoin[]" singular="queryJoin"/>
    </transfer>

    <transfer name="QueryJoin">
        <property name="whereConditions" type="QueryWhereCondition[]" singular="queryWhereCondition"/>
    </transfer>

    <transfer name="QueryWhereCondition">
        <property name="column" type="string"/>
        <property name="value" type="string"/>
        <property name="comparison" type="string"/>
    </transfer>

</transfers>
