<?xml version="1.0"?>
<config>
    <purchasing-control>
        <label>Cost Centers</label>
        <title>Cost Centers</title>
        <icon>fa-building</icon>
        <bundle>purchasing-control</bundle>
        <controller>cost-center</controller>
        <action>index</action>
        <pages>
            <cost-center-create>
                <label>Create Cost Center</label>
                <title>Create Cost Center</title>
                <bundle>purchasing-control</bundle>
                <controller>cost-center</controller>
                <action>create</action>
                <visible>0</visible>
            </cost-center-create>
            <cost-center-edit>
                <label>Edit Cost Center</label>
                <title>Edit Cost Center</title>
                <bundle>purchasing-control</bundle>
                <controller>cost-center</controller>
                <action>edit</action>
                <visible>0</visible>
            </cost-center-edit>
            <cost-center-budget>
                <label>Budgets</label>
                <title>Budgets</title>
                <bundle>purchasing-control</bundle>
                <controller>budget</controller>
                <action>index</action>
                <visible>0</visible>
                <pages>
                    <budget-create>
                        <label>Create Budget</label>
                        <title>Create Budget</title>
                        <bundle>purchasing-control</bundle>
                        <controller>budget</controller>
                        <action>create</action>
                        <visible>0</visible>
                    </budget-create>
                    <budget-edit>
                        <label>Edit Budget</label>
                        <title>Edit Budget</title>
                        <bundle>purchasing-control</bundle>
                        <controller>budget</controller>
                        <action>edit</action>
                        <visible>0</visible>
                    </budget-edit>
                </pages>
            </cost-center-budget>
        </pages>
    </purchasing-control>
</config>
