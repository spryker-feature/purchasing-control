<?xml version="1.0"?>
<config>
    <purchasing-control>
        <label>Purchasing Control</label>
        <title>Purchasing Control</title>
        <icon>fa-building</icon>
        <bundle>purchasing-control</bundle>
        <controller>cost-center</controller>
        <action>index</action>
        <pages>
            <cost-center-create>
                <label>Create Cost Center</label>
                <title>Create Cost Center</title>
                <bundle>purchasing-control</bundle>
                <controller>cost-center</controller>
                <action>create</action>
                <visible>0</visible>
            </cost-center-create>
            <cost-center-edit>
                <label>Edit Cost Center</label>
                <title>Edit Cost Center</title>
                <bundle>purchasing-control</bundle>
                <controller>cost-center</controller>
                <action>edit</action>
                <visible>0</visible>
            </cost-center-edit>
            <cost-center-budget>
                <label>Budgets</label>
                <title>Budgets</title>
                <bundle>purchasing-control</bundle>
                <controller>budget</controller>
                <action>index</action>
                <visible>0</visible>
            </cost-center-budget>
        </pages>
    </purchasing-control>
</config>
