{% extends '@Gui/Layout/layout.twig' %}

{% set widget_title = 'Edit Cost Center' | trans %}

{% block head_title -%}
    {{ widget_title }}
{%- endblock %}

{% block section_title %}{{ widget_title }}{% endblock %}

{% block action %}
    {{ backActionButton(url('/purchasing-control/cost-center/index'), 'Back to Cost Centers' | trans) }}
{% endblock %}

{% block content %}
    {% embed '@Gui/Partials/widget.twig' with { widget_title: 'Edit Cost Center' | trans } %}
        {% block widget_content %}
            {% include '@PurchasingControl/Partials/_cost-center-form.twig' with {
                form: costCenterForm,
            } only %}
        {% endblock %}
    {% endembed %}
{% endblock %}
