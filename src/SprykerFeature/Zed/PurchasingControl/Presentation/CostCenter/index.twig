{% extends '@Gui/Layout/layout.twig' %}

{% set widget_title = 'Cost Centers' | trans %}

{% block head_title -%}
    {{ widget_title }}
{%- endblock %}

{% block section_title %}{{ widget_title }}{% endblock %}

{% block action %}
    {{ createActionButton(url('/purchasing-control/cost-center/create'), 'Create Cost Center' | trans) }}
{% endblock %}

{% block content %}
    {% embed '@Gui/Partials/widget.twig' with { widget_title: 'Cost Centers' | trans } %}
        {% block widget_content %}
            {{ costCenterTable | raw }}
        {% endblock %}
    {% endembed %}
{% endblock %}
